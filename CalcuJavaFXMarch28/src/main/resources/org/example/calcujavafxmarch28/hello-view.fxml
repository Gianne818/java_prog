<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" maxHeight="400.0" maxWidth="350.0" minHeight="400.0" minWidth="350.0" prefHeight="400.0" prefWidth="350.0" spacing="20.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.calcujavafxmarch28.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <TextField fx:id="tfAnswer" alignment="CENTER_RIGHT" editable="false" prefHeight="0.0" prefWidth="160.0" text="0">
      <font>
         <Font size="18.0" />
      </font></TextField>
    
   <TilePane alignment="CENTER" hgap="20.0" maxHeight="250.0" maxWidth="250.0" minHeight="250.0" minWidth="250.0" prefColumns="3" prefHeight="250.0" prefRows="4" prefWidth="250.0" vgap="20.0">
      <children>
         <Button mnemonicParsing="false" onAction="#onBtnNumberClicked" text="7">
            <font>
               <Font size="18.0" />
            </font></Button>
         <Button mnemonicParsing="false" onAction="#onBtnNumberClicked" text="8">
            <font>
               <Font size="18.0" />
            </font></Button>
         <Button mnemonicParsing="false" onAction="#onBtnNumberClicked" text="9">
            <font>
               <Font size="18.0" />
            </font></Button>
         <Button mnemonicParsing="false" onAction="#onBtnOperatorClicked" text="+">
            <font>
               <Font size="18.0" />
            </font></Button>
         <Button mnemonicParsing="false" onAction="#onBtnNumberClicked" text="4">
            <font>
               <Font size="18.0" />
            </font></Button>
         <Button mnemonicParsing="false" onAction="#onBtnNumberClicked" text="5">
            <font>
               <Font size="18.0" />
            </font></Button>
         <Button mnemonicParsing="false" onAction="#onBtnNumberClicked" text="6">
            <font>
               <Font size="18.0" />
            </font></Button>
         <Button mnemonicParsing="false" onAction="#onBtnOperatorClicked" text="-">
            <font>
               <Font size="18.0" />
            </font></Button>
         <Button mnemonicParsing="false" onAction="#onBtnNumberClicked" text="1">
            <font>
               <Font size="18.0" />
            </font></Button>
         <Button mnemonicParsing="false" onAction="#onBtnNumberClicked" text="2">
            <font>
               <Font size="18.0" />
            </font></Button>
         <Button mnemonicParsing="false" onAction="#onBtnNumberClicked" text="3">
            <font>
               <Font size="18.0" />
            </font></Button>
         <Button mnemonicParsing="false" onAction="#onBtnOperatorClicked" text="*">
            <TilePane.margin>
               <Insets />
            </TilePane.margin>
            <font>
               <Font size="18.0" />
            </font></Button>
         <Button fx:id="btnClear" mnemonicParsing="false" onAction="#onBtnClearClicked" text="C">
            <font>
               <Font size="18.0" />
            </font>
         </Button>
         <Button mnemonicParsing="false" onAction="#onBtnNumberClicked" text="0">
            <font>
               <Font size="18.0" />
            </font>
         </Button>
         <Button mnemonicParsing="false" onAction="#onBtnOperatorClicked" text="=">
            <font>
               <Font size="18.0" />
            </font>
         </Button>
         <Button mnemonicParsing="false" onAction="#onBtnOperatorClicked" text="/">
            <font>
               <Font size="18.0" />
            </font>
         </Button>
      </children>
   </TilePane>
</VBox>
