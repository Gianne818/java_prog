<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: #c3d2de;" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.javafxapril14.screens.landing.LandingController">
    <children>
        <HBox alignment="CENTER" spacing="20.0" style="-fx-background-color: linear-gradient(to bottom, #C3D2DE,  #867e32);" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox alignment="TOP_CENTER" prefHeight="402.0" prefWidth="601.0" spacing="10.0" style="-fx-background-radius: 20; -fx-background-color: #F3F1EB;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label text="Welcome,">
                                    <font><Font name="System Bold" size="24.0" /></font>
                                </Label>
                                <Label fx:id="labelFullName" text="Name">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                </Label>
                            </children>
                        </HBox>
                        <VBox spacing="5.0">
                            <children>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Your Username:">
                                            <font>
                                                <Font size="14.0" />
                                            </font></Label>
                                        <Label fx:id="labelUsername" text="---">
                                            <font>
                                                <Font size="14.0" />
                                            </font></Label>
                                    </children>
                                </HBox>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label style="-fx-font-weight: bold;" text="Your User ID:">
                                            <font>
                                                <Font size="14.0" />
                                            </font></Label>
                                        <Label fx:id="labelUserId" text="---">
                                            <font>
                                                <Font size="14.0" />
                                            </font></Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <Separator prefWidth="200.0" />
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Session Information">
                                    <font><Font name="System Bold" size="18.0" /></font>
                                </Label>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label text="Login Time:">
                                            <font>
                                                <Font size="14.0" />
                                            </font></Label>
                                        <Label fx:id="labelLoginTime" text="---">
                                            <font>
                                                <Font size="14.0" />
                                            </font></Label>
                                    </children>
                                </HBox>
                                <HBox spacing="10.0">
                                    <children>
                                        <Label text="Session Status:">
                                            <font>
                                                <Font size="14.0" />
                                            </font></Label>
                                        <Label fx:id="labelSessionStatus" style="-fx-font-weight: bold;" text="Active" textFill="#2ecc71">
                                            <font>
                                                <Font size="14.0" />
                                            </font></Label>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>

                <VBox alignment="CENTER_LEFT" prefHeight="402.0" prefWidth="601.0" spacing="15.0" style="-fx-background-radius: 20; -fx-background-color: #F3F1EB;">
                    <children>
                        <Label text="Change Password">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Label>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Current Password:">
                                    <font>
                                        <Font size="14.0" />
                                    </font></Label>
                                <PasswordField fx:id="pfCurrentPassword" style="-fx-background-radius: 10;" />
                                <Label text="New Password:">
                                    <font>
                                        <Font size="14.0" />
                                    </font></Label>
                                <PasswordField fx:id="pfNewPassword" style="-fx-background-radius: 10;" />
                            </children>
                        </VBox>
                        <Button fx:id="btnChangePassword" maxWidth="Infinity" onAction="#onChangePasswordClick" mnemonicParsing="false" style="-fx-background-radius: 50; -fx-border-color: #554436; -fx-background-color: #F3F1EB; -fx-border-radius: 50;" text="Update Password">
                            <font>
                                <Font size="14.0" />
                            </font></Button>
                        <Separator prefWidth="200.0" />
                        <Button fx:id="btnLogout" maxWidth="Infinity" mnemonicParsing="false" onAction="#onLogoutClick" style="-fx-background-color: #554436; -fx-background-radius: 60;" text="LOGOUT" textFill="#f3f1eb">
                            <font><Font name="System Bold" size="18.0" /></font>
                        </Button>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </children>
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
        </HBox>
    </children>
</AnchorPane>